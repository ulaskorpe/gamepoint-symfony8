{% trans_default_domain 'project' %}
<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}{{ 'app.default_title'|trans }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-md navbar-dark bg-dark border-bottom shadow-sm">
    <div class="container d-flex flex-wrap align-items-center">
        <a class="navbar-brand fw-semibold" href="{{ path('app_home') }}">{{ 'nav.brand'|trans }}</a>
        <div class="navbar-nav flex-row gap-1 gap-md-2 align-items-center me-auto ms-2 ms-md-3">
            <a class="nav-link link-light py-1 px-2" href="{{ path('app_home') }}">{{ 'nav.games'|trans }}</a>
            <a class="nav-link link-light py-1 px-2" href="{{ path('app_tech') }}">{{ 'nav.technical'|trans }}</a>
        </div>
        <div class="ms-auto d-flex flex-wrap align-items-center gap-2 py-1">
            <div class="dropdown">
                <a class="nav-link link-light py-1 px-2 dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" data-bs-display="static" aria-expanded="false" aria-label="{{ 'nav.language'|trans }}">
                    {{ 'nav.language'|trans }}
                </a>
                <ul class="dropdown-menu dropdown-menu-end">
                    {% set locale_route = app.request.attributes.get('_route') %}
                    {% set locale_params = app.request.attributes.get('_route_params')|default({}) %}
                    {% if locale_params._locale is defined and locale_route %}
                        <li><a class="dropdown-item" 
                        href="{{ path(locale_route, locale_params|merge({ _locale: 'tr' })) }}">
                        {{ 'nav.locale_tr'|trans }}</a></li>
                        <li><a class="dropdown-item" href="{{ path(locale_route, locale_params|merge({ _locale: 'en' })) }}">{{ 'nav.locale_en'|trans }}</a></li>
                    {% else %}
                        <li><a class="dropdown-item" href="{{ path('app_home', { _locale: 'tr' }) }}">
                        {{ 'nav.locale_tr'|trans }}</a></li>
                        <li><a class="dropdown-item" href="{{ path('app_home', { _locale: 'en' }) }}">{{ 'nav.locale_en'|trans }}</a></li>
                    {% endif %}
                </ul>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2" role="navigation" aria-label="{{ 'nav.auth_aria_label'|trans }}">
                {% if app.user %}
                    <span class="text-white-50 small">{{ app.user.userIdentifier }}</span>
                    <a class="btn btn-outline-light btn-sm" href="{{ path('app_logout') }}">{{ 'nav.logout'|trans }}</a>
                {% else %}
                    <a class="btn btn-outline-light btn-sm" href="{{ path('app_login') }}">{{ 'nav.login'|trans }}</a>
                    <a class="btn btn-primary btn-sm" href="{{ path('app_register') }}">{{ 'nav.register'|trans }}</a>
                {% endif %}
            </div>
        </div>
    </div>
</nav>
{% block body %}{% endblock %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
