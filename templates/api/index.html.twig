{% extends 'base.html.twig' %}
{% trans_default_domain 'project' %}

{% block title %}{{ 'api.page_title'|trans }} — {{ parent() }}{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 800px;">
        <div class="card-body">
            <h1 class="h4 mb-3">{{ 'api.heading'|trans }}</h1>
            <p class="text-muted mb-0">{{ 'api.intro'|trans }}</p>
        </div>
    </div>
</div>
{% endblock %}
