{% extends 'base.html.twig' %}

{% block title %}Giriş — {{ parent() }}{% endblock %}

{% block body %}
<div class="min-vh-100 d-flex align-items-center justify-content-center p-4">
    <div class="card shadow-sm" style="max-width: 420px; width: 100%;">
        <div class="card-body p-4">
            <h1 class="h4 text-center mb-4">Giriş</h1>

            {% if error %}
                <div class="alert alert-danger" role="alert">Kullanıcı adı veya şifre hatalı.</div>
            {% endif %}

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            <form method="post" action="{{ path('app_login') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <div class="mb-3">
                    <label for="username" class="form-label">Kullanıcı adı</label>
                    <input type="text" class="form-control" id="username" name="_username" value="{{ last_username }}" autocomplete="username" required>
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Şifre</label>
                    <input type="password" class="form-control" id="password" name="_password" autocomplete="current-password" required>
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="remember_me" name="_remember_me">
                    <label class="form-check-label" for="remember_me">Beni hatırla</label>
                </div>
                <button type="submit" class="btn btn-primary w-100">Giriş yap</button>
            </form>
            <p class="text-center text-muted small mt-3 mb-0">
                Hesabın yok mu? <a href="{{ path('app_register') }}">Kayıt ol</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
