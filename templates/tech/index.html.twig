{% extends 'base.html.twig' %}
{% trans_default_domain 'project' %}

{% block title %}{{ 'nav.technical_records'|trans }} — {{ parent() }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css">
{% endblock %}

{% block body %}
<div class="container py-4">
    <div id="tech-page-data" class="d-none" hidden
        data-swal-title="{{ 'tech.delete_swal_title'|trans|e('html_attr') }}"
        data-swal-text="{{ 'tech.delete_swal_text'|trans|e('html_attr') }}"
        data-swal-confirm="{{ 'tech.delete_swal_confirm'|trans|e('html_attr') }}"
        data-swal-cancel="{{ 'tech.delete_swal_cancel'|trans|e('html_attr') }}"
        data-dt-lang-tr="https://cdn.datatables.net/plug-ins/1.13.7/i18n/tr.json"
        data-dt-lang-en="https://cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"
    ></div>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h1 class="h5 mb-0">{{ 'nav.technical_records'|trans }}</h1>
            <a class="btn btn-primary btn-sm" href="{{ path('app_tech_create') }}">{{ 'tech.btn_create'|trans }}</a>
        </div>
        <div class="card-body">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message|trans }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="{{ 'auth.login.alert_close'|trans }}"></button>
                    </div>
                {% endfor %}
            {% endfor %}
            {% if technicals is empty %}
                <p class="text-muted mb-0">{{ 'tech.empty_list'|trans }}</p>
            {% else %}
                <div class="table-responsive">
                    <table id="tech-table" class="table table-striped table-hover align-middle w-100">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">{{ 'tech.col_title'|trans }}</th>
                                <th scope="col">{{ 'tech.col_description'|trans }}</th>
                                <th scope="col" class="text-nowrap">{{ 'tech.col_created'|trans }}</th>
                                <th scope="col" class="text-end text-nowrap">{{ 'tech.col_actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for t in technicals %}
                                <tr>
                                    <td class="fw-medium">{{ t.title }}</td>
                                    <td class="text-muted small" style="max-width: 28rem;">
                                        {% if t.description %}
                                            <span class="d-inline-block text-truncate w-100" title="{{ t.description|e('html_attr') }}">{{ t.description }}</span>
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td class="text-nowrap small text-muted" data-order="{{ t.createdAt ? t.createdAt|date('U') : 0 }}">
                                        {% if t.createdAt %}
                                            {{ t.createdAt|date('d.m.Y H:i') }}
                                        {% else %}
                                            —
                                        {% endif %}
                                    </td>
                                    <td class="text-end text-nowrap">
                                        <a class="btn btn-sm btn-outline-primary" href="{{ path('app_tech_edit', { id: t.id }) }}">{{ 'tech.btn_edit'|trans }}</a>
                                        <button type="button" class="btn btn-sm btn-outline-danger" data-tech-delete data-tech-id="{{ t.id }}">{{ 'tech.btn_delete'|trans }}</button>
                                        <form id="tech-delete-form-{{ t.id }}" method="post" action="{{ path('app_tech_delete', { id: t.id }) }}" class="d-none">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_technical_' ~ t.id) }}">
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{% if technicals is not empty %}
<script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function () {
    var cfg = document.getElementById('tech-page-data');
    var tableEl = document.getElementById('tech-table');
    if (tableEl && typeof jQuery !== 'undefined' && jQuery.fn.DataTable) {
        var langUrl = '{{ app.request.locale }}' === 'tr'
            ? (cfg ? cfg.dataset.dtLangTr : '')
            : (cfg ? cfg.dataset.dtLangEn : '');
        jQuery(tableEl).DataTable({
            language: { url: langUrl },
            order: [[0, 'asc']],
            pageLength: 15,
            lengthMenu: [[10, 15, 25, 50], [10, 15, 25, 50]],
            columnDefs: [
                { targets: 3, orderable: false, searchable: false }
            ],
            autoWidth: false
        });
    }
    if (!cfg) return;
    document.body.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-tech-delete]');
        if (!btn) return;
        var id = btn.getAttribute('data-tech-id');
        var form = document.getElementById('tech-delete-form-' + id);
        if (!form) return;
        e.preventDefault();
        Swal.fire({
            title: cfg.dataset.swalTitle,
            text: cfg.dataset.swalText,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: cfg.dataset.swalConfirm,
            cancelButtonText: cfg.dataset.swalCancel
        }).then(function (result) {
            if (result.isConfirmed) {
                form.submit();
            }
        });
    });
})();
</script>
{% endif %}
{% endblock %}
